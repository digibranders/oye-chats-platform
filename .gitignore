# Documents (Keep folder structure, but ignore content)
api/documents/*
api/archive/*
!api/documents/.gitkeep
!api/archive/.gitkeep

# Database / Secrets
.env
*.db
*.sqlite

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
ENV/
.coverage
htmlcov/

# Distribution / packaging
dist/
node_modules/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*

# Editor / System
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.gemini/
brain/
.claude/

widget/.wrangler/

# Brevo template backups (created by scripts/upload_brevo_templates.py)
api/emails/.backup/

# Email rendering preview (generated artifact, not source-of-truth)
api/emails/preview/

# Personal local-dev launcher (API + ARQ worker side-by-side, env overrides)
api/dev.sh

# Machine-specific uv config (points to local conda env path)
api/uv.toml
