# Database
DB_URL=postgresql://user:password@localhost:5432/oyechats

# LLM (via LiteLLM — primary: OpenAI, fallback: Gemini)
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-gemini-api-key-here
# LLM_MODEL=openai/gpt-5-mini
# FALLBACK_MODEL=google/gemini-2.5-flash

# Backblaze B2 Cloud Storage
R2_KEY_ID=your-r2-key-id
R2_APPLICATION_KEY=your-r2-application-key
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT=s3.us-west-004.backblazeb2.com

# App Environment (development | production)
APP_ENV=development

# Google OAuth — "Sign in with Google" for the admin dashboard (optional).
# Both CLIENT_ID and CLIENT_SECRET must be set to enable the button; if either
# is missing the /auth/google/* routes 503 and the frontend hides the button.
# Credentials: Google Cloud Console → APIs & Services → Credentials → Web client.
# GOOGLE_REDIRECT_URI must be registered verbatim as an Authorized redirect URI
# on that same client. Prod values live in GitHub Secrets (injected by the
# deploy workflow); the redirect/success URLs are hardcoded there for prod.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5174/auth/callback
# OAUTH_STATE_SECRET=  # stable random; shared across workers (falls back to SECRET_KEY)

# CORS Origins (comma-separated, only used when APP_ENV=production)
# CORS_ORIGINS=https://oyechats.com,https://app.oyechats.com,https://www.oyechats.com

# Redis (required for the worker and rate limiter; cache layer degrades gracefully when unset)
# Local dev: `brew install redis && brew services start redis`, then use the URL below.
# Production runs Redis on the same droplet on loopback (see runbooks/2026-04-27-redis-upstash-to-local.md).
# REDIS_URL=redis://localhost:6379/0

# Sentry Error Tracking (optional — leave blank to disable)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Langfuse Observability — DEV project keys (optional — leave blank to disable)
# Use keys from your "OyeChats Dev" Langfuse project, NOT the production project.
# Prod keys live in GitHub Secrets and are injected by the deploy workflow.
# Creating a separate project keeps dev traces out of the prod dashboard.
# cloud.langfuse.com → Settings → Projects → New Project → "OyeChats Dev"
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Crawl provider ──────────────────────────────────────────────
# playwright (default) | spider
CRAWL_PROVIDER=playwright
SPIDER_API_KEY=
SPIDER_API_URL=https://api.spider.cloud
SPIDER_REQUEST_MODE=smart
SPIDER_TIMEOUT=1600
SPIDER_FALLBACK_TO_PLAYWRIGHT=true
